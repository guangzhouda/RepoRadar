# GitHub API
GITHUB_TOKEN=
GITHUB_SEARCH_PER_PAGE=10

# LLM provider configuration.
# DeepSeek uses an OpenAI-compatible API surface, so keep base URL and model in
# environment variables instead of hardcoding provider-specific URLs in code.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# Local runtime
REPORADAR_CACHE_DIR=.reporadar_cache
REPORADAR_LOG_LEVEL=INFO

